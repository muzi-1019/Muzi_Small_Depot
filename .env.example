RAG_APP_NAME=RAG Role-Play System
RAG_APP_ENV=dev
RAG_APP_DEBUG=true

RAG_MYSQL_DSN=mysql+pymysql://root:root@localhost:3306/rag_roleplay
RAG_REDIS_URL=redis://localhost:6379/0
RAG_MILVUS_URI=http://localhost:19530
RAG_MILVUS_ENABLED=false
RAG_MILVUS_COLLECTION=character_knowledge

RAG_LLM_PROVIDER=siliconflow
RAG_LLM_MODEL_NAME=deepseek-ai/DeepSeek-V3
RAG_OPENAI_API_BASE=https://api.siliconflow.cn/v1
RAG_OPENAI_API_KEY=
RAG_SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1

RAG_JWT_SECRET=change-me-in-production
RAG_JWT_EXPIRE_MINUTES=1440

RAG_SHORT_MEMORY_ROUNDS=20
RAG_RETRIEVAL_TOP_K=8
RAG_RERANK_TOP_K=5
RAG_MAX_CONCURRENT_ROLES_PER_USER=3
RAG_ACTIVE_ROLE_IDLE_SECONDS=3600

RAG_UPLOAD_DIR=uploads
